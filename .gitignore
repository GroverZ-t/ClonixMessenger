## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/
*.sln.iml

# NuGet Packages
*.nupkg
**/packages/*

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Visual Studio cache files
*.cache
project.lock.json
project.fragment.lock.json
artifacts/

# OS-specific
.DS_Store
.AppleDouble
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Rider
.idea/

# MAUI specific
**/bin/**
**/obj/**
**/.vs/**